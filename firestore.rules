rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // "Cet utilisateur appartient-il à cette résidence ?" — dénormalisé sur
    // users/{uid}.residencesIds (maintenu par databases_user_services.dart /
    // databases_lot_services.dart), car les règles Firestore ne peuvent pas
    // parcourir residences/{id}/lots pour vérifier idProprietaire/idLocataire
    // sans connaître un lotId précis.
    function isResidenceMember(residenceId) {
      return isSignedIn() &&
        residenceId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.residencesIds;
    }

    // Dénormalisé sur users/{uid}.csMemberResidencesIds (maintenu par
    // sync_cs_member_residences, cf. functions_python/main.py) : "est-il CS
    // member de N'IMPORTE QUELLE résidence" pour autoriser la création d'un
    // contact partagé (collection racine "contacts") - le rattachement à une
    // résidence précise vit sur residences/{id}.contactRefs, pas sur ce
    // document, donc pas de residencesIds à comparer ici. Champ absent tant
    // que la fonction n'a pas tourné pour cet utilisateur -> gardé par
    // 'x in ... .data', même pattern défensif que isSyndicAgent plus bas.
    function isCsMemberOfAnyResidenceAtAll() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && 'csMemberResidencesIds' in userData &&
        userData.csMemberResidencesIds.size() > 0;
    }

    // csmembers est déjà le bon endroit pour ce check : c'est un champ direct
    // sur residences/{id}, accessible sans dénormalisation supplémentaire.
    function isCsMember(residenceId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/residences/$(residenceId)).data.csmembers;
    }

    // Un bailleur consulte le dossier (identité, profil, garants) d'un
    // locataire qui lui est rattaché — dénormalisé sur
    // users/{tenantUid}.sharedWithLandlords (maintenu par addTenant /
    // removeIdLocataire dans databases_lot_services.dart).
    function isSharedTenantDoc(tenantUid) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(tenantUid)).data.sharedWithLandlords;
    }

    // Un bailleur a reçu une demande de location (onglet "Demandes" de
    // ManagementTenant) mais n'a pas encore ajouté ce locataire à un lot :
    // dénormalisé sur users/{tenantUid}.pendingDemandeLandlords (maintenu par
    // shareFile() dans firestore_user_repository.dart), pour qu'il puisse
    // consulter le dossier avant de décider de l'accepter.
    function isPendingDemandeLandlord(tenantUid) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/users/$(tenantUid)).data.pendingDemandeLandlords;
    }

    // Un document individuel (users/{uid}/lots/{lotId}/documents) est déposé
    // en copie chez chaque destinataire du lot (locataires + propriétaires,
    // cf my_docs.dart deleteDocument). Le propriétaire du lot doit donc
    // pouvoir le supprimer chez tous les destinataires, pas seulement sa
    // propre copie.
    function isLotOwner(residenceId, lotId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/residences/$(residenceId)/lots/$(lotId)).data.idProprietaire;
    }

    // ---------- Rôles de compte (accountType) : RBAC backoffice web ----------
    // accountType ('utilisateur'|'superAdmin'|'agence'|'agent') est verrouillé
    // côté client (cf. règle users/{uid} plus bas) : seul le backoffice web
    // (Admin SDK, hors règles - cf. invite_agency_account dans
    // functions_python/main.py) peut le positionner à autre chose que
    // 'utilisateur'. 'agence'/'agent' sont deux "sièges" vendus par licence à
    // une gérance (une adresse mail = un compte), scopés aux résidences dont
    // geranceRef.geranceId pointe vers leur gérance (cf.
    // isProfessionnelResidence/isProfessionnelLot ci-dessous) - 'agence' a en
    // plus accès aux actions sensibles/destructrices, 'agent' non (cf.
    // isAgenceAccount).

    // Super Admin plateforme : accès complet à toute résidence/lot. Ajouté en
    // || sur les règles ci-dessous plutôt qu'un bypass global en tête de
    // fichier, pour rester visible collection par collection.
    function isSuperAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'superAdmin';
    }

    // Compte "siège principal" d'une gérance (backoffice web, RBAC) : les
    // deux valeurs d'accountType 'agence'/'agent' partagent le même
    // périmètre de résidences (cf. isProfessionnelResidence/Lot ci-dessous),
    // mais seul 'agence' a accès aux actions sensibles/destructrices
    // (archiver, annuler, supprimer, approuver, fusionner) - 'agent' reste
    // en lecture seule dessus. Utilisé en plus de, jamais à la place de,
    // isProfessionnelResidence/isProfessionnelLot (qui vérifient le
    // périmètre résidence/lot, pas le niveau de droits).
    function isAgenceAccount() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'agence';
    }

    function isAgenceOrAgentAccount() {
      let accountType = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType;
      return isSignedIn() && (accountType == 'agence' || accountType == 'agent');
    }

    // Agent d'une gérance pour un service donné (serviceSyndic ou
    // geranceLocative) : dénormalisé sur gerances/{id}.serviceSyndicAgentUids
    // / geranceLocativeAgentUids (tableaux plats d'UIDs), maintenus par
    // invite_agency_account/revoke_agency_account (functions_python/main.py) -
    // seule source de vérité pour l'appartenance à une gérance, users/{uid}
    // ne portant pas ce lien lui-même.
    // 'in' sur un champ absent lève une erreur : gardé par 'x in gerance'.
    function isSyndicAgent(geranceId) {
      let gerance = get(/databases/$(database)/documents/gerances/$(geranceId)).data;
      return isSignedIn() && 'serviceSyndicAgentUids' in gerance &&
        request.auth.uid in gerance.serviceSyndicAgentUids;
    }

    function isGeranceLocativeAgent(geranceId) {
      let gerance = get(/databases/$(database)/documents/gerances/$(geranceId)).data;
      return isSignedIn() && 'geranceLocativeAgentUids' in gerance &&
        request.auth.uid in gerance.geranceLocativeAgentUids;
    }

    // Un Professionnel "serviceSyndic" a accès à TOUTE la résidence (le
    // syndic gère l'immeuble entier) ; un Professionnel "geranceLocative"
    // n'a accès qu'au(x) LOT(S) précis référençant sa gérance (cf.
    // isProfessionnelLot), jamais à toute la résidence - granularité validée
    // avec l'utilisateur (project note "rôles de compte").
    function isProfessionnelResidence(residenceId) {
      let residence = get(/databases/$(database)/documents/residences/$(residenceId)).data;
      return isSignedIn() && 'geranceRef' in residence &&
        residence.geranceRef.serviceType == 'serviceSyndic' &&
        isSyndicAgent(residence.geranceRef.geranceId);
    }

    function isProfessionnelLot(residenceId, lotId) {
      let lot = get(/databases/$(database)/documents/residences/$(residenceId)/lots/$(lotId)).data;
      return isSignedIn() && 'geranceRef' in lot &&
        lot.geranceRef.serviceType == 'geranceLocative' &&
        isGeranceLocativeAgent(lot.geranceRef.geranceId);
    }

    // Un Professionnel serviceSyndic peut corriger le téléphone d'un
    // résident dont il gère AU MOINS une résidence (users/{uid}.residencesIds,
    // déjà dénormalisé pour isResidenceMember) - déroulé sur les 3 premiers
    // éléments faute de boucle possible sur un tableau dynamique en règles,
    // limitation assumée (un résident a rarement plus de 2-3 résidences
    // actives). geranceLocative non couvert ici : ses lots vivent dans une
    // sous-collection (users/{uid}/lots), pas exposés comme tableau sur ce
    // document racine.
    function isProfessionnelForAnyResidence(residenceIds) {
      return (residenceIds.size() > 0 && isProfessionnelResidence(residenceIds[0])) ||
        (residenceIds.size() > 1 && isProfessionnelResidence(residenceIds[1])) ||
        (residenceIds.size() > 2 && isProfessionnelResidence(residenceIds[2]));
    }

    // users/{uid}/lots/{lotId}/documents : residenceId résolu depuis le lot
    // DESTINATAIRE {uid} (chemin de la requête, jamais resource.data du
    // document /documents/{docId} lui-même) - safe pour une requête *list*,
    // contrairement à users/{uid}/lots où ce même besoin (residenceId
    // inconnu à l'avance) exige un where() côté client (cf. commentaire
    // dédié sur cette collection, backoffice web).
    function canAccessRecipientLotDocuments(uid, lotId) {
      let recipientLot = get(/databases/$(database)/documents/users/$(uid)/lots/$(lotId)).data;
      return isCsMember(recipientLot.residenceId) ||
        isProfessionnelResidence(recipientLot.residenceId) ||
        isProfessionnelLot(recipientLot.residenceId, lotId);
    }

    // ---------- users ----------
    match /users/{uid} {
      // Recherche par email/refApp (ajout locataire/garant), affichage
      // profil (ProfilTile) dans posts/chat/commentaires partout dans l'app.
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && request.resource.data.isApproved == false &&
        request.resource.data.accountType == 'utilisateur';
      // isApproved/accountType ne doivent jamais être modifiables par le
      // propriétaire du compte lui-même (seule une approbation manuelle
      // hors-app, ou le futur backoffice web pour accountType, peut les
      // changer) - mais un Super Admin, lui, DOIT pouvoir le faire : c'est
      // précisément son rôle (remplacer l'approbation manuelle Console par
      // une vraie UI). Les comptes créés avant l'ajout d'accountType n'ont
      // pas ce champ : traité comme 'utilisateur' par défaut des deux côtés
      // de la comparaison, pour ne pas bloquer les mises à jour normales.
      // Même traitement pour isApproved : un compte agence/agent créé par
      // invite_agency_account n'a jamais ce champ (absent, pas juste false)
      // - un accès direct en dot-notation lève une erreur d'évaluation sur
      // les deux côtés de la comparaison et bloquait AUCUNE auto-édition
      // (ex: /profil) pour ces comptes, faute de garde 'in'.
      allow update: if isSuperAdmin() || (isOwner(uid) &&
        (('isApproved' in request.resource.data) ? request.resource.data.isApproved : false) ==
        (('isApproved' in resource.data) ? resource.data.isApproved : false) &&
        (('accountType' in request.resource.data) ? request.resource.data.accountType : 'utilisateur') ==
        (('accountType' in resource.data) ? resource.data.accountType : 'utilisateur')) ||
        // Correction du téléphone d'un résident par le professionnel qui
        // gère (au moins) une de ses résidences (cf. updateUserPhone,
        // ResidentDetailPage) - jamais le reste de l'identité, réservé
        // superAdmin (cf. commentaire ci-dessus).
        (isAgenceOrAgentAccount() &&
          'residencesIds' in resource.data &&
          isProfessionnelForAnyResidence(resource.data.residencesIds) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profil']));
      // Suppression gérée par le flux dédié (Auth supprimé d'abord, puis
      // purge des données), jamais par un delete direct depuis le client.
      allow delete: if false;

      // Champs à lecture restreinte au propriétaire (ex: token FCM) :
      // Firestore ne permet pas de restreindre la lecture d'un champ
      // précis sur un document (allow read s'applique à tout le document),
      // donc ces champs vivent dans un document séparé plutôt que sur
      // User/{uid} lui-même (lisible par tout utilisateur connecté pour
      // l'affichage du profil ailleurs dans l'app).
      match /private/{docId} {
        allow read, write: if isOwner(uid);
      }

      // private/profilLocataire : revenus/situation familiale/téléphone du
      // dossier locataire (CRIT 2 - ex sous-collection profil_locataire à
      // document unique, ID toujours = uid). Visibilité plus large que
      // private/{docId} ci-dessus (le bailleur qui a ce locataire en partage
      // doit pouvoir consulter son dossier) : match spécifique en plus du
      // match générique, les deux s'additionnent (Firestore autorise si au
      // moins un match correspondant l'autorise).
      match /private/profilLocataire {
        allow read: if isOwner(uid) || isSharedTenantDoc(uid) || isPendingDemandeLandlord(uid);
        allow write: if isOwner(uid);
      }

      match /lots/{lotId} {
        allow read: if isOwner(uid) || isCsMember(resource.data.residenceId) || isSuperAdmin() ||
          isProfessionnelResidence(resource.data.residenceId) ||
          isProfessionnelLot(resource.data.residenceId, lotId);
        allow create: if isOwner(uid) && request.resource.data.isApprovedLot == false;
        // isApprovedLot ne doit jamais être modifiable par le propriétaire du
        // compte (même logique que users/{uid}.isApproved) : seul un Super
        // Admin, ou une Agence gérant cette résidence/ce lot (cas gérance/
        // syndic du domain model - jamais un simple Agent), peut le repasser
        // à true (remplace la validation manuelle Console après vérification
        // humaine des documents déposés).
        allow update: if isSuperAdmin() || ((isOwner(uid) || isCsMember(resource.data.residenceId)) &&
          request.resource.data.isApprovedLot == resource.data.isApprovedLot) ||
          (isAgenceAccount() && (isProfessionnelResidence(resource.data.residenceId) ||
            isProfessionnelLot(resource.data.residenceId, lotId)));
        allow delete: if isOwner(uid) || isCsMember(resource.data.residenceId) || isSuperAdmin();

        match /documents/{docId} {
          // Un seul get() sur le lot du DESTINATAIRE {uid} (chemin connu à
          // l'avance depuis les segments de la requête, jamais depuis
          // resource.data) - donc, contrairement à users/{uid}/lots
          // lui-même, aucun souci pour une requête *list* ici.
          allow read: if isOwner(uid) || isSharedTenantDoc(uid) || isSuperAdmin() ||
            canAccessRecipientLotDocuments(uid, lotId);
          // isLotOwner résout residenceId depuis le lot du PROPRIÉTAIRE
          // AGISSANT (request.auth.uid), pas celui du destinataire {uid} :
          // un propriétaire doit pouvoir nettoyer la copie d'un locataire
          // depuis révoqué (users/{uid}/lots/{lotId} déjà supprimé par la
          // révocation - cf _removeIdLocataireInternal), donc on ne peut
          // pas dépendre d'un document qui n'existe plus forcément côté
          // destinataire. Le propriétaire, lui, a toujours son propre
          // users/{request.auth.uid}/lots/{lotId} tant qu'il possède ce lot.
          allow write: if isOwner(uid) ||
            isLotOwner(get(/databases/$(database)/documents/users/$(request.auth.uid)/lots/$(lotId)).data.residenceId, lotId) ||
            isCsMember(get(/databases/$(database)/documents/users/$(uid)/lots/$(lotId)).data.residenceId);
        }
      }

      // Archive d'un lot quitté (retrait ou auto-détachement), copie à plat
      // écrite par sync_lot_tenants (privilèges Admin) - cf. commentaire de
      // _recompute_tenant_denormalization. Lecture seule pour l'intéressé,
      // jamais écrite depuis le client.
      match /lotsOld/{lotId} {
        allow read: if isOwner(uid);
        allow write: if false;

        match /documents/{docId} {
          allow read: if isOwner(uid);
          allow write: if false;
        }
      }

      // Documents d'identité.
      match /documents/{docId} {
        allow read: if isOwner(uid) || isSharedTenantDoc(uid) || isPendingDemandeLandlord(uid) || isSuperAdmin();
        allow write: if isOwner(uid);
      }

      // Garants du dossier locataire (CRIT 2 - déplacé depuis
      // profil_locataire/{uid}/garants, un niveau de nesting en moins).
      match /garants/{garantId} {
        allow read: if isOwner(uid) || isSharedTenantDoc(uid) || isPendingDemandeLandlord(uid);
        allow write: if isOwner(uid);

        match /documents/{docId} {
          allow read: if isOwner(uid) || isSharedTenantDoc(uid) || isPendingDemandeLandlord(uid);
          allow write: if isOwner(uid);
        }
      }

      match /demandes_loc/{id} {
        // Le locataire émetteur (resource.data.tenantId) doit pouvoir lister
        // ("Mes demandes en cours", requête collectionGroup) et retirer ses
        // propres demandes envoyées, même si le document vit chez le
        // bailleur destinataire (uid du chemin), pas chez lui.
        allow read: if isOwner(uid) || (isSignedIn() && resource.data.tenantId == request.auth.uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid) || (isSignedIn() && resource.data.tenantId == request.auth.uid);
        // shareFile() écrit chez le bailleur trouvé (uid du chemin), pas
        // chez l'appelant : on vérifie donc que l'appelant se déclare bien
        // comme émetteur (tenantId), pas qu'il est propriétaire du doc.
        allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      }

      // Copie figée d'une demande refusée (cf. refuseDemande côté Dart) :
      // survit à un retrait de la demande d'origine (demandes_loc) côté
      // locataire, pour l'onglet "Historique" du bailleur. Lecture/écriture
      // réservées au bailleur (uid du chemin) - le locataire n'a pas besoin
      // d'y accéder, le motif étant déjà dupliqué sur demandes_loc lui-même.
      match /demandes_historique/{id} {
        allow read, write: if isOwner(uid);
      }

      // Notifications persistées (nouveau post / nouvelle demande de
      // location) en plus du push FCM déjà envoyé - écrites uniquement par
      // les Cloud Functions (functions/index.js, Admin SDK). Seul "read" est
      // modifiable depuis l'app (marquer comme lu).
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow create, delete: if false;
      }
    }

    // ---------- residences ----------
    match /residences/{residenceId} {
      // Recherche de résidence à l'inscription (step1.dart) : un nouvel
      // utilisateur n'a encore aucun users/{uid} ni aucune appartenance —
      // il doit pouvoir lister/lire residences pour choisir la sienne.
      allow read: if isSignedIn();
      allow update: if isCsMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
      // Création/suppression d'une résidence hors périmètre de l'app
      // résident : réservée au backoffice web (konodal_bo), donc gatée sur
      // isSuperAdmin() plutôt que bloquée totalement.
      allow create, delete: if isSuperAdmin();

      match /lots/{lotId} {
        // Comme pour residences/{id} : un nouvel utilisateur doit pouvoir
        // parcourir la liste des lots pour choisir le sien à l'inscription
        // (step3.dart, getLotByResidence), avant d'être membre de la
        // résidence (isResidenceMember serait toujours faux à ce stade).
        allow read: if isSignedIn();
        allow create, delete: if isCsMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
        // Le propriétaire du lot peut ajouter/retirer des locataires
        // (addTenant / removeIdLocataire) sans être CS member, mais
        // uniquement sur idLocataire (+ idLocataireOld, l'historique des
        // locataires révoqués, écrit dans la même requête).
        allow update: if isCsMember(residenceId) || isSuperAdmin() ||
          // Professionnel (syndic sur toute la résidence, gérance locative
          // sur CE lot précisément) : uniquement les champs descriptifs,
          // jamais idProprietaire/idLocataire/parentLotId/isLinkable (gérés
          // exclusivement par CS member/Super Admin ou par le propriétaire
          // lui-même via les branches dédiées ci-dessous).
          ((isProfessionnelResidence(residenceId) || isProfessionnelLot(residenceId, lotId)) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['typeLot', 'batiment', 'lot', 'refLot', 'type'])) ||
          (isSignedIn() && request.auth.uid in resource.data.idProprietaire &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['idLocataire', 'idLocataireOld'])) ||
          // "Détacher ce lot" (ModifyProperty) : l'inverse du rattachement -
          // un propriétaire ou un locataire peut se retirer LUI-MÊME (jamais
          // quelqu'un d'autre), sans rien modifier d'autre. sync_lot_tenants
          // se charge du nettoyage dénormalisé (users/{uid}/lots,
          // residencesIds, sharedWithLandlords) déclenché par cette écriture.
          (isSignedIn() &&
           request.auth.uid in resource.data.idProprietaire &&
           !(request.auth.uid in request.resource.data.idProprietaire) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['idProprietaire'])) ||
          (isSignedIn() &&
           request.auth.uid in resource.data.idLocataire &&
           !(request.auth.uid in request.resource.data.idLocataire) &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['idLocataire', 'idLocataireOld'])) ||
          // Lier/délier/regrouper (ModifyProperty) : réservé au propriétaire
          // de CE lot. Déliaison (parentLotId absent/null dans la nouvelle
          // valeur) toujours autorisée. Liaison/regroupement : CE lot
          // (l'enfant) doit être isLinkable=true (décidé par un CS member à
          // la création, jamais par le propriétaire - empêche de lier un
          // logement principal entier à un autre pour s'y ajouter sans
          // justificatif), ET le propriétaire doit aussi posséder le lot
          // parent visé (jamais de transfert de propriété involontaire -
          // sync_lot_tenants aligne ensuite idProprietaire/idLocataire de
          // l'enfant sur le parent avec des privilèges admin).
          (isSignedIn() &&
           request.auth.uid in resource.data.idProprietaire &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['parentLotId', 'groupedWithParent']) &&
           (
             !('parentLotId' in request.resource.data) ||
             request.resource.data.parentLotId == null ||
             (
               resource.data.isLinkable == true &&
               request.auth.uid in get(/databases/$(database)/documents/residences/$(residenceId)/lots/$(request.resource.data.parentLotId)).data.idProprietaire
             )
           ));
      }

      match /posts/{postId} {
        allow read: if isResidenceMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
        // isSuperAdmin() en création : le backoffice crée des events
        // "prestation" pour une résidence dont il n'est pas forcément
        // membre - même bypass que read/update/delete ci-dessous. Agence/
        // Agent (isProfessionnelResidence) ont le même bypass, SAUF pour
        // programmer une intervention depuis un sinistre (linkedSinistreId
        // renseigné) - réservé Superadmin, cf. matrice de droits BO.
        allow create: if (isResidenceMember(residenceId) &&
          request.resource.data.user == request.auth.uid) || isSuperAdmin() ||
          (isProfessionnelResidence(residenceId) && !('linkedSinistreId' in request.resource.data));
        // Modération : un CS member peut éditer/supprimer n'importe quel
        // post, pas seulement les siens (comportement actuel de l'app).
        // Liker le post de quelqu'un d'autre est aussi un update() Firestore
        // - autorisé séparément à tout résident du groupe, uniquement si le
        // seul champ modifié est "like" (même pattern que les commentaires).
        // Une fois declaredDate posé (transmission à la gérance), impossible
        // de repasser le statut à "Non envoyé" - règle absolue, y compris
        // pour isSuperAdmin. Agence/Agent (isProfessionnelResidence) peuvent
        // modifier statut/priorité/contenu, mais seule une Agence (pas un
        // simple Agent) peut toucher archived/annule - actions jugées
        // sensibles dans la matrice de droits BO (archiver un sinistre,
        // annuler une intervention).
        allow update: if (
          (isResidenceMember(residenceId) &&
            (resource.data.user == request.auth.uid || isCsMember(residenceId) ||
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['like']))) ||
          isSuperAdmin() ||
          (isProfessionnelResidence(residenceId) &&
            (isAgenceAccount() ||
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['archived', 'annule'])))
        ) && !(
          resource.data.get('declaredDate', null) != null &&
          request.resource.data.statut == 'Non envoyé'
        );
        allow delete: if isResidenceMember(residenceId) &&
          (resource.data.user == request.auth.uid || isCsMember(residenceId)) ||
          isSuperAdmin();

        match /signalements/{id} {
          allow create: if isResidenceMember(residenceId);
          // Affiché à tout résident de la résidence (carrousel de
          // doublons sur un post dans Homeview, "Voir plus (N)" sur les
          // tuiles sinistres/incivilités/annonces) - la modération
          // (update/delete) reste réservée aux CS members (+ Super Admin).
          allow read: if isResidenceMember(residenceId) || isSuperAdmin();
          allow update, delete: if isCsMember(residenceId) || isSuperAdmin();
        }

        match /comments/{id} {
          // isSuperAdmin() en lecture/création : le backoffice affiche et
          // répond aux commentaires d'un post (ex: fil sous un sinistre) sans
          // que ce compte soit résident de la résidence.
          allow read, create: if isResidenceMember(residenceId) || isSuperAdmin();
          // Édition/suppression complète réservée à l'auteur (ou modération) ;
          // mais liker le commentaire de quelqu'un d'autre est aussi un
          // update() Firestore - autorisé séparément à tout résident du
          // groupe, uniquement si le seul champ modifié est "like".
          allow update: if resource.data.user == request.auth.uid || isCsMember(residenceId) ||
            isSuperAdmin() ||
            (isResidenceMember(residenceId) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['like']));
          allow delete: if resource.data.user == request.auth.uid || isCsMember(residenceId) || isSuperAdmin();

          match /replies/{id} {
            allow read, create: if isResidenceMember(residenceId) || isSuperAdmin();
            allow update: if resource.data.user == request.auth.uid || isCsMember(residenceId) ||
              isSuperAdmin() ||
              (isResidenceMember(residenceId) &&
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['like']));
            allow delete: if resource.data.user == request.auth.uid || isCsMember(residenceId) || isSuperAdmin();
          }
        }
      }

      match /deletedPosts/{postId} {
        // Archive créée par removePost (batch, atomique avec le delete du
        // post) au moment où un CS member supprime un post - conserve le
        // contenu complet + la raison, réservé à la modération.
        allow read: if isCsMember(residenceId) || isSuperAdmin();
        allow create: if isCsMember(residenceId) || isSuperAdmin();
      }

      match /chats/{chatId} {
        // Doc ID = deux uids triés joints par "_" — suffisant pour un get()
        // direct (chatInfoStream), mais une requête de LISTE non filtrée
        // (MessageProvider.listenForMessages, qui parcourt tous les chats
        // d'une résidence pour détecter les nouveaux messages) doit pouvoir
        // être prouvée par Firestore à partir du filtre where de la requête,
        // donc sur le contenu (from_id/to_id), pas sur l'ID du document.
        allow get: if isSignedIn() && request.auth.uid in chatId.split('_');
        allow list: if isSignedIn() &&
          (resource.data.from_id == request.auth.uid || resource.data.to_id == request.auth.uid);
        allow create: if isSignedIn() &&
          (request.resource.data.from_id == request.auth.uid || request.resource.data.to_id == request.auth.uid);
        allow update, delete: if isSignedIn() && request.auth.uid in chatId.split('_');

        match /messages/{msgId} {
          allow read, write: if isSignedIn() && request.auth.uid in chatId.split('_');
        }
      }

      match /structures/{id} {
        allow read: if isResidenceMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
        allow write: if isCsMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
      }

      match /documents_copro/{id} {
        allow read: if isResidenceMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
        allow write: if isCsMember(residenceId) || isSuperAdmin() || isProfessionnelResidence(residenceId);
      }

      match /mail/{id} {
        allow read, write: if isResidenceMember(residenceId) || isSuperAdmin();
      }

      match /events/{id} {
        // Professionnel : volontairement AUCUN accès (communications/
        // événements résidents hors périmètre du CS, cf. project note
        // "rôles de compte" - décision produit explicite).
        allow read: if isResidenceMember(residenceId) || isSuperAdmin();
        // Un non-CS ne peut créer qu'un événement de type "evenement"
        // (event_form.dart) ; un CS member peut créer tous les types.
        allow create: if isResidenceMember(residenceId) &&
          (isCsMember(residenceId) || request.resource.data.type == "evenement");
        allow update, delete: if isCsMember(residenceId) || isSuperAdmin();
      }
    }

    // ---------- Root "mail" (Firebase Trigger Email extension) ----------
    // Différente de residences/{id}/mail. Jamais écrite par le client Flutter
    // (l'écriture applicative passe par residences/{id}/mail). Le schéma réel
    // (to/from = adresse email de l'agence/syndic, pas celle du résident
    // connecté) rend un scoping par request.auth.token.email inapplicable
    // sans casser les requêtes existantes : fermée pour l'instant.
    match /mail/{id} {
      allow read, write: if false;
    }

    // ---------- Root "transactions" ----------
    // Aucune référence trouvée dans lib/ ni functions/ : collection non
    // utilisée par l'app actuellement.
    match /transactions/{id} {
      allow read, write: if false;
    }

    // ---------- Root "emergencyContactsFr" ----------
    // Contacts d'urgence génériques (non sensibles, non scopés résidence).
    match /emergencyContactsFr/{id} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---------- Root "contacts" (annuaire partagé multi-résidences) ----------
    // Remplace l'ancienne sous-collection residences/{id}/contacts (un
    // contact dupliqué par résidence, supprimée depuis que plus aucun code
    // ne la lit/l'écrit - cf. migrate_contacts_to_root.py pour la reprise de
    // données historique). Le rattachement à une résidence ne vit PLUS ici mais
    // sur residences/{id}.contactRefs : Firestore n'a pas de sécurité par
    // champ, donc exposer residencesIds sur ce document partagé permettait à
    // un Professionnel gérant UNE résidence liée de voir TOUTES les autres
    // résidences liées (fuite cross-agence). En sortant le rattachement sur
    // le document résidence (déjà lisible par tout isSignedIn(), une
    // résidence à la fois), il n'y a plus de tableau cross-résidence à
    // corréler. Match RACINE EXPLICITE (pas {path=**}) : gerances/{id}/contacts
    // portait le même nom de collection (annuaire d'agences, sans rapport)
    // mais a été supprimé - la recherche par email itère maintenant sur
    // users/{uid}, cf. FirestoreAgencyRepository.searchByEmail.
    match /contacts/{id} {
      // Plus rien de sensible par résidence sur ce document une fois
      // residencesIds sorti - même niveau d'ouverture que residences/{id}.
      allow read: if isSignedIn();
      // Une création côté app ne peut jamais s'auto-approuver (isApproved
      // doit naître à false) - seul un Super Admin (backoffice) revalide
      // ensuite. Même verrou que isApproved (users/{uid}) / isApprovedLot.
      // Plus de résidence précise à vérifier dans le payload (le
      // rattachement se fait séparément sur residences/{id}.contactRefs).
      // Agence/Agent (backoffice web) peuvent aussi créer un contact - pas
      // de scoping résidence possible ici (annuaire partagé multi-agences,
      // cf. commentaire en tête de bloc), donc ouvert à tout compte
      // professionnel, pas seulement ceux liés à une résidence précise.
      allow create: if (isCsMemberOfAnyResidenceAtAll() &&
        request.resource.data.isApproved == false) || isSuperAdmin() ||
        (isAgenceOrAgentAccount() && request.resource.data.isApproved == false);
      // Fiche (nom/service/coordonnées) modifiable par tout compte
      // professionnel ; approbation (isApproved) et nettoyage doublons
      // (likelyDuplicateIds, cf. dismissDuplicate/mergeContacts côté BO)
      // réservés à une Agence (pas un simple Agent) - actions jugées
      // sensibles dans la matrice de droits BO.
      allow update: if isSuperAdmin() ||
        (isAgenceOrAgentAccount() &&
          (isAgenceAccount() ||
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved', 'likelyDuplicateIds'])));
      // Jamais de delete direct par l'app : réservé au Super Admin ou à une
      // Agence (nettoyage manuel, qui détache aussi contactRefs sur les
      // résidences concernées) - pas un simple Agent.
      allow delete: if isSuperAdmin() || isAgenceAccount();
    }

    // ---------- Root "shareTokens" (liens de partage à portée limitée) ----------
    // Un token = accès en LECTURE à UNE intervention précise (+ son sinistre
    // lié), envoyé par email à un prestataire externe sans compte BO. Jamais
    // lu ici via une requête Firestore cliente : c'est la Cloud Function
    // get_shared_intervention (Admin SDK, functions_python/main.py) qui
    // résout le token et sert les données, donc aucune règle "public" n'est
    // nécessaire - seul le BO (génération du lien) a besoin d'écrire/lire ce
    // document directement.
    match /shareTokens/{token} {
      allow read, write: if isSuperAdmin();
    }

    // ---------- Root "adCampaigns" (publicité inter-résidences) ----------
    // Campagne gérée uniquement par le backoffice (image, ciblage
    // targetResidenceIds, période startDate/endDate) - l'app ne fait que lire
    // les campagnes actives et incrémenter les compteurs de suivi
    // (impressionCount/clickCount). `active` n'est plus jamais écrit par le
    // BO : c'est reconcile_ad_campaigns_* (functions_python/main.py, Admin
    // SDK) qui l'active/désactive selon la période et le quota de 3
    // campagnes actives par département. Le filtre "active" DOIT rester dans la
    // requête cliente (FirestoreAdCampaignRepository.watchActiveCampaign) :
    // une requête de liste qui ne filtre pas elle-même sur un champ dont
    // dépend la règle est refusée en bloc par Firestore, même sans aucun
    // document qui violerait réellement la règle (cf. incident déjà vécu sur
    // posts/{postId}, type "rapport").
    match /adCampaigns/{id} {
      // isSuperAdmin() en bypass de lecture/écriture pour le backoffice web
      // (konodal_bo, gestion des campagnes) : cette condition ne dépend PAS
      // de resource.data, donc pas de risque de reproduire l'incident
      // posts/{postId} - le filtre "active" reste uniquement nécessaire côté
      // requête app résident (non-superAdmin), inchangé.
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.active == true);
      // Un résident ne peut faire évoluer que impressionCount/clickCount et
      // leur répartition par résidence (impressionsByResidence/
      // clicksByResidence, écriture en chemin pointé "champ.$residenceId" -
      // affectedKeys() ne reporte que la clé de premier niveau, pas la
      // sous-clé résidence) - même pattern que "like" sur les posts ; le
      // backoffice superAdmin peut éditer librement (image, ciblage,
      // fréquence, statut actif).
      allow update: if isSuperAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['impressionCount', 'clickCount', 'impressionsByResidence', 'clicksByResidence']));
      allow create, delete: if isSuperAdmin();

      // Journal détaillé événement par événement (qui, quand, depuis quelle
      // résidence) - en plus des compteurs agrégés ci-dessus, pour un
      // rapport de campagne précis côté BO. La résidence sert de dimension
      // géographique (pas la position de l'utilisateur : un résident peut se
      // connecter loin de son lot, et une gérance multi-résidences fausserait
      // le signal si on utilisait sa position réelle). Immutable une fois
      // créé - aucun update/delete, même pour l'auteur.
      match /impressions/{eventId} {
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow read: if isSuperAdmin();
      }
      match /clicks/{eventId} {
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow read: if isSuperAdmin();
      }
    }

    // ---------- Root "config" (réglages globaux backoffice) ----------
    // Singleton config/adCampaigns : fréquence d'affichage des pubs, commune
    // à toutes les campagnes (retirée du modèle par-campagne, cf. adCampaigns
    // ci-dessus) - lu par tous les résidents (home_view.dart), écrit
    // uniquement par le backoffice.
    match /config/adCampaigns {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Règle dédiée aux requêtes collectionGroup('demandes_loc')
    // (getSentDemandes, "Mes demandes en cours" côté locataire) : même
    // raison que contacts ci-dessus - la règle imbriquée users/{uid}/
    // demandes_loc/{id} ne couvre que les lectures/deletes à chemin connu
    // (users/{landlordId}/demandes_loc/{id} déjà résolu), pas une requête
    // cross-documents à travers tous les users/{uid} d'un coup.
    match /{path=**}/demandes_loc/{id} {
      allow read: if isSignedIn() && resource.data.tenantId == request.auth.uid;
    }

    // ---------- gerances (annuaire syndic/agence) ----------
    // Sous-collections récursives à profondeur/nom dynamique, lecture seule
    // côté app, non sensible.
    match /gerances/{id} {
      allow read: if isSignedIn();
      // Annuaire syndic/agences : édition réservée au Super Admin, plus une
      // Agence (pas un simple Agent) éditant SA PROPRE fiche depuis le
      // backoffice web (isSyndicAgent/isGeranceLocativeAgent vérifient déjà
      // l'appartenance à CETTE gérance précise, id) - un Professionnel ne
      // gère toujours pas sa fiche gérance depuis l'app résident (aucun
      // accès accountType='agence'/'agent' prévu côté app mobile).
      // serviceSyndicAgentUids/geranceLocativeAgentUids exclus de ce bypass
      // à dessein : une Agence ne doit jamais pouvoir s'auto-ajouter (ou
      // ajouter un tiers) elle-même à ces tableaux, sous peine de
      // s'octroyer l'accès à d'autres résidences - seul invite_agency_account/
      // revoke_agency_account (Cloud Function Admin SDK, réservée Super
      // Admin appelant) les modifie.
      allow write: if isSuperAdmin() ||
        (isAgenceAccount() && (isSyndicAgent(id) || isGeranceLocativeAgent(id)) &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['serviceSyndicAgentUids', 'geranceLocativeAgentUids']));

      match /{document=**} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin();
      }
    }
  }
}
